APP_ENV=development
APP_NAME=ZAPP Internal Dashboard API
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_ORIGIN=http://127.0.0.1:5173

# PostgreSQL connection for dashboard-owned data.
DATABASE_URL=<local-or-supabase-postgres-url>

# Existing ZAPP API. Keep the real token in your local .env or deployment secrets only.
ZAPP_API_BASE_URL=https://receipt-verification-app.onrender.com
ZAPP_API_TOKEN=replace-with-secure-token
ZAPP_SHOP_DOMAIN=your-store.myshopify.com
ZAPP_API_TIMEOUT_SECONDS=10

# Auth. Use a long random value in local .env/deployment secrets.
JWT_SECRET=replace-with-secure-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Basic in-process rate limits. Use external rate limiting at the edge for multi-instance production.
AUTH_RATE_LIMIT_REQUESTS=8
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
DIAGNOSTICS_RATE_LIMIT_REQUESTS=20
DIAGNOSTICS_RATE_LIMIT_WINDOW_SECONDS=300
